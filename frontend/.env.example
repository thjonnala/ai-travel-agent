# Copy to .env.local and fill in. All values here are PUBLIC (bundled into the
# client) — never put secrets in frontend env vars.

# Entra ID (External ID / B2C) app registration for the SPA — used from milestone 2.
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY=
VITE_ENTRA_API_SCOPE=

# Only needed when the API is NOT reached via the Vite dev proxy (e.g. deployed
# Static Web App pointing at App Service). Leave empty for local dev.
VITE_API_BASE_URL=
