# Copy to .env.local and fill in. All values here are PUBLIC (bundled into the
# client) — never put secrets in frontend env vars.

# Absolute origin of the consolidated thiru-apps-api (Azure App Service). Leave
# empty for local dev — Vite proxies /api to http://localhost:5080. Trip routes
# live under /api/sat. The production value is set in .env.production.
VITE_API_BASE_URL=
