# Copy to .env.local and fill in. All values here are PUBLIC (bundled into the
# client) — never put secrets in frontend env vars.

# Absolute origin of the deployed backend API (Render). Leave empty for local
# dev — Vite proxies /api to http://localhost:5054.
# Example: https://ai-travel-agent-api.onrender.com
VITE_API_BASE_URL=
