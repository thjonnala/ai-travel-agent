      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" Version="10.2.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TravelAgent.Application\TravelAgent.Application.csproj" />
    <ProjectReference Include="..\TravelAgent.Infrastructure\TravelAgent.Infrastructure.csproj" />
  </ItemGroup>

</Project>
